# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in emails and QR codes)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Lavo <hello@getlavo.io>
SUPPORT_EMAIL=harold@getlavo.io
BUILDING_REQUEST_FROM_EMAIL=Harold <harold@getlavo.io>
BUILDING_REQUEST_OPS_EMAILS=harold@getlavo.io,haroldtrakhman@gmail.com
# ADMIN_EMAIL=haroldtrakhman@gmail.com  # internal alerts only — not shown in email footers

# PostHog (optional — client analytics + session replay)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron protection (optional — set a random secret to protect cron endpoints)
CRON_SECRET=

# Google Places (optional — powers the building search bar; falls back to Photon if absent)
GOOGLE_PLACES_API_KEY=

# Anthropic (optional — lets the "Find with AI" button look up management contact info)
ANTHROPIC_API_KEY=
